# ─── API + WORKER ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/contentpulse
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-at-least-32-chars-long
JWT_REFRESH_SECRET=change-me-different-32-chars

PORT=3001
LOG_LEVEL=info

# ─── AI ───────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=         # sk-or-... — leave empty to use stub adapter
OPENAI_API_KEY=             # sk-... — DALL·E 3 — leave empty for stubs

# Model selection — override to swap models without touching source code
# Free tier defaults (good for MVP testing):
AI_MODEL_GENERATION=anthropic/claude-haiku-4.5   # ideas, drafts, regeneration
AI_MODEL_RESEARCH=anthropic/claude-haiku-4.5    # research briefs
AI_MODEL_VISUAL=dall-e-3                                       # OpenAI — image generation

# ─── TREND SOURCES ────────────────────────────────────────────────────────────
X_API_BEARER_TOKEN=         # leave empty for stubs
NEWSAPI_KEY=                # leave empty for stubs
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
YOUTUBE_API_KEY=            # leave empty for stubs

# ─── MEDIA ────────────────────────────────────────────────────────────────────
UNSPLASH_ACCESS_KEY=        # leave empty for stubs
PEXELS_API_KEY=             # leave empty for stubs

# ─── STORAGE (Cloudflare R2) ──────────────────────────────────────────────────
R2_ACCOUNT_ID=              # leave empty to use local ./tmp/r2 filesystem
R2_ACCESS_KEY_ID=
R2_SECRET_KEY=
R2_BUCKET_NAME=contentpulse
R2_PUBLIC_URL=              # e.g. https://pub-xyz.r2.dev

# ─── EMAIL ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=             # re_... — leave empty for stub

# ─── PUSH NOTIFICATIONS ───────────────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:hello@contentpulse.app

# ─── MONITORING ───────────────────────────────────────────────────────────────
SENTRY_DSN_BACKEND=         # optional

# ─── FRONTEND (Next.js, browser-safe) ─────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001/v1/ws
